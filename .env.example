# =============================
# 1) RPC / Sidecar (Required)
# =============================
# Rust bot RPC
SOLANA_HTTP_URL=
SOLANA_WS_URL=

# Sidecar RPC (TypeScript). Keep consistent with SOLANA_HTTP_URL.
RPC_URL=

# Sidecar service endpoint
SIDECAR_URL=http://127.0.0.1:8080
SIDECAR_PORT=8080

# =============================
# 2) Subscription
# =============================
# ws | grpc
SUBSCRIPTION_MODE=grpc

# Required when SUBSCRIPTION_MODE=grpc
GRPC_ENDPOINT=
# Optional auth token for gRPC provider
GRPC_X_TOKEN=
# Optional tuning
# GRPC_MAX_ACCOUNTS_PER_FILTER=200
# WS_MAX_SUBS_PER_CONNECTION=300

# =============================
# 3) Trading Core
# =============================
# Opportunity alert threshold (bps)
ARBITRAGE_ALERT_BPS=5

# Spot-only quote-in mode (recommended)
ARBITRAGE_TRADE_SIZE_QUOTE=0.5
# Optional quote range mode
# ARBITRAGE_TRADE_MIN_QUOTE=0.3
# ARBITRAGE_TRADE_MAX_QUOTE=0.8

# Legacy base mode (optional)
# ARBITRAGE_TRADE_SIZE=0.1
# ARBITRAGE_TRADE_MIN=0.05
# ARBITRAGE_TRADE_MAX=0.2

# Opportunity decision buffer (pct)
SLIPPAGE_BUFFER_PCT=0.3

# false = monitor only, true = build/send execution flow
ENABLE_TRADE_EXECUTION=false
# true = simulate only (no send)
ARBITRAGE_DRY_RUN_ONLY=true

# true = start monitor loop
ENABLE_MONITOR=true
# true = only export pools and exit
EXPORT_POOLS_ONLY=false

# Optional misc
# BASE_TX_FEE_LAMPORTS=5000
# DRY_RUN_SWEEP=false

# =============================
# 4) Pool Discovery / Filters
# =============================
MIN_TVL_USD=50000
MIN_VOL24H_USD=5000
POOL_REFRESH_SECS=3600

# DexScreener fetch controls
DEXSCREENER_MIN_LIQUIDITY=50000
DEXSCREENER_DELAY_MS=100

# Optional source filters
# POOL_QUOTE_WHITELIST=So11111111111111111111111111111111111111112
# POOL_WHITELIST=
# POOL_BLACKLIST=
# MAX_DYNAMIC_POOLS=

# Pair intersection filter
# PAIR_INTERSECTION_ONLY=false
# PAIR_INTERSECTION_DEXES=meteora_dlmm,orca_whirlpool

# Optional static pools (forced subscribe)
# ORCA_POOLS=
# RAYDIUM_POOLS=
# METEORA_DAMM_V1_POOLS=
# METEORA_DAMM_POOLS=
# METEORA_LB_POOLS=
# METEORA_DLMM_POOLS=
# PUMP_FUN_POOLS=
# DISABLE_RAYDIUM_LEGACY=false

# Optional source knobs
# METEORA_MIN_TVL=50000
# OUTPUT_MIN_LIQUIDITY=50000
# MORALIS_API_KEY=
# PUMP_API_LIMIT=200
# PUMP_MIN_USD_MARKET_CAP=10000
# PUMP_PROGRAM_ID=6EF8rrecthR5Dkzon8Nwu78hRvfCKubJ14M5uBEwF6P

# =============================
# 5) Slippage / Warmup
# =============================
POOL_FILTER_TRADE_SIZE_QUOTE=0.5
# POOL_FILTER_MAX_SLIPPAGE_BPS=50
SLIPPAGE_REFRESH_INTERVAL_MINS=20
BUY_SLIPPAGE_BUFFER_BPS=10

# Tick/bin cache refresh controls
# TICK_BIN_CACHE_REFRESH_SLOTS=300
# TICK_BIN_CACHE_REFRESH_MIN_GAP_SLOTS=50

# =============================
# 6) Accounts / WSOL
# =============================
# Required for live execution
SOLANA_SIGNER_KEYPAIR=

# If true, assume wSOL ATA already funded
SKIP_WSOL_WRAP=true

# Optional per-pool account override
# TRADE_ACCOUNTS=pool=<pubkey>|side=buy|payer=<pk>|base=<pk>|quote=<pk>;pool=<pubkey>|side=sell|payer=<pk>|base=<pk>|quote=<pk>

# =============================
# 7) ALT / Jito
# =============================
ALT_AUTO_EXTEND=true
JITO_LOOKUP_TABLES=
JITO_TIP_LAMPORTS=50000

# Optional Jito routing/auth
# JITO_TIP_RECEIVER=
# JITO_RELAY_URL=
JITO_GRPC_URL=
# JITO_GRPC_AUTH_KEYPAIR=
# JITO_AUTH_KEYPAIR=

FORCE_JITO_GRPC_SUBSCRIBE=true
DISABLE_JITO_GRPC_SUBSCRIBE=false
# DISABLE_JITO_BUNDLE_STATUS_RPC=false

# Dynamic tip = est_profit_pct * DYNAMIC_TIP_PROFIT_PCT%
# DYNAMIC_TIP_PROFIT_PCT=30

# =============================
# 8) Strategy / Cooldown
# =============================
PAIR_COOLDOWN_SECS=60
# STRATEGY_POOL_WHITELIST=
# STRATEGY_POOL_BLACKLIST=
# STRATEGY_COOLDOWN_DURATION_SECS=60
# STRATEGY_COOLDOWN_FAILURE_THRESHOLD=3
# STRATEGY_MAX_ACTIVE_JOBS_PER_POOL=1
# STRATEGY_MIN_NET_QUOTE=0.0
# STRATEGY_MIN_SPREAD_PCT=0.0

# =============================
# 9) Dispatcher / Performance
# =============================
# Launcher build toggle (run_with_sidecar.sh defaults to false)
# CARGO_PROFILE_RELEASE_LTO=false

# DISPATCHER_QUEUE_CAPACITY=1024
# DISPATCHER_MAX_CONCURRENT=1
# DISPATCHER_STATUS_POLL_MS=500
# DISPATCHER_IMMEDIATE=false
# DISPATCHER_FORCE_IMMEDIATE=false
# DISPATCHER_IGNORE_GUARDS=false

# PROCESS_UPDATE_CONCURRENCY=8
# PROCESS_UPDATE_TIMEOUT_SECS=15
# TOKIO_WORKER_THREADS=8

# =============================
# 10) DEX Execution Overrides
# =============================
# DLMM_EXECUTION_DEFAULT_SLIPPAGE_BPS=
# DLMM_EXECUTION_SLIPPAGE_BPS=
# DLMM_EXECUTION_CONFIG=
# DLMM_CALIBRATION_CONFIG=
# DLMM_ACTIVE_RANGE=
# DLMM_MAX_BIN_ARRAYS=
# DLMM_EXECUTION_POOLS=
# DLMM_EXECUTION_USER=
# DLMM_EXECUTION_SIDE=
# DLMM_EXECUTION_AMOUNT=
# DLMM_EXECUTION_HOST_FEE_IN=
# DLMM_EXECUTION_USER_TOKEN_IN=
# DLMM_EXECUTION_USER_TOKEN_OUT=
# DLMM_EXECUTION_TOKEN_X_PROGRAM=
# DLMM_EXECUTION_TOKEN_Y_PROGRAM=
# DLMM_EXECUTION_ADDITIONAL_ACCOUNTS=
# DLMM_EXECUTION_BIN_EXTENSION=
# METEORA_BIN_WINDOW=

# Pump.fun execution profile overrides
# PUMPFUN_EXECUTION_POOLS=
# PUMPFUN_EXECUTION_USER=
# PUMPFUN_EXECUTION_SIDE=
# PUMPFUN_EXECUTION_AMOUNT=
# PUMPFUN_EXECUTION_SLIPPAGE_BPS=
# PUMPFUN_EXECUTION_TRACK_VOLUME=false
# PUMPFUN_EXECUTION_USER_BASE_ATA=
# PUMPFUN_EXECUTION_USER_QUOTE_ATA=
